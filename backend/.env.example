# TuShare Token（可选）
TUSHARE_TOKEN=
# 飞书机器人 Webhook（可选）
FEISHU_WEBHOOK=
# 经济新闻 RSS 补充源，逗号分隔（内置已含央视/东财/华尔街等，一般留空即可）
NEWS_RSS_URLS=
# 新闻「最新」窗口（小时），保留该时间内快讯；更早的仅保留宏观/政策类
NEWS_FRESH_HOURS=24
# 可选：大模型 API Key（未配置时使用规则解读）
OPENAI_API_KEY=
PAPER_INITIAL_CASH=1000000
MAX_POSITION_PCT=0.25
MAX_TOTAL_EXPOSURE=0.95
